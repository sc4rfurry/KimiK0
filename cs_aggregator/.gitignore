# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# ─── Distribution / Packaging ────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
*.whl
*.tar.gz

# ─── Virtual Environments ────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.vs/

# ─── Testing / Coverage ──────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.tox/

# ─── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Sensitive / Payload Data ─────────────────────────────────────────────────
# NEVER commit real CS payloads, shellcode samples, or C2 profile exports
Payload/
*.bin
*.dll
*.exe
*.shellcode
*.raw
*.dump
*.dmp

# Exclude test extraction output directories
test_extraction/
output/

# ─── Environment / Secrets ───────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
*.p12

# ─── Lock Files (optional — uncomment if you want to track) ──────────────────
# uv.lock

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.log
*.bak
*.tmp
